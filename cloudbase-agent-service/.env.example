PORT=9000

# OpenAI-compatible model endpoint.
# Keep real secrets in `.env`, and keep this file as a shareable template only.
OPENAI_API_KEY=replace-with-your-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat


# Tencent WebService key for search / walking / geocoder tools.
TMAP_WEBSERVICE_KEY=replace-with-your-tencent-map-key

# Active map provider: tencent | baidu
MAP_PROVIDER=tencent

# Optional Baidu Map AK for place search / reverse geocoder / walking route.
BAIDU_MAP_AK=replace-with-your-baidu-map-ak

# Optional scene switch
DEFAULT_SCENE_ID=tsinghua-spring
